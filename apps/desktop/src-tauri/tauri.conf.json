{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Release Publisher",
  "version": "0.1.0",
  "identifier": "com.example.releasepublisher",
  "build": {
    "beforeDevCommand": "pnpm --filter @release-publisher/desktop dev",
    "beforeBuildCommand": "pnpm --filter @release-publisher/desktop build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Release Publisher",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: asset:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
